{
  "name": "quiet",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "node scripts/clean-dist.js && npm run build && electron-builder --win && node scripts/rename-update-files.js",
    "build:mac": "node scripts/clean-dist.js && npm run build && electron-builder --mac && node scripts/rename-update-files.js",
    "build:linux": "node scripts/clean-dist.js && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.13.5",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.3.9",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "sockjs-client": "^1.6.1",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fast-check/vitest": "^0.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.19.1",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "cli-truncate": "^4.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "happy-dom": "^20.7.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
